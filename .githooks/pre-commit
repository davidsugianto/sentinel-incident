#!/bin/bash
#
# Pre-commit hook for Sentinel Incident
# This script runs before each commit to ensure code quality
#
# To install:
#   Option 1: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   Option 2: git config core.hooksPath .githooks
#

set -e

echo "🔍 Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# Function to run a check
run_check() {
    local name="$1"
    local command="$2"

    echo -e "${YELLOW}▶${NC} Running $name..."
    if eval "$command"; then
        echo -e "${GREEN}✓${NC} $name passed"
    else
        echo -e "${RED}✗${NC} $name failed"
        FAILED=1
    fi
}

# Check 1: Go format
echo -e "${YELLOW}▶${NC} Running go fmt..."
FMT_OUTPUT=$(gofmt -l . | grep -v '^vendor' | grep -v '^tmp' | grep -v '^bin' || true)
if [ -z "$FMT_OUTPUT" ]; then
    echo -e "${GREEN}✓${NC} go fmt passed"
else
    echo -e "${RED}✗${NC} go fmt failed. Files need formatting:"
    echo "$FMT_OUTPUT"
    FAILED=1
fi

# Check 2: go mod tidy
echo -e "${YELLOW}▶${NC} Running go mod tidy..."
go mod tidy
if git diff --exit-code go.mod go.sum > /dev/null 2>&1; then
    echo -e "${GREEN}✓${NC} go mod tidy passed"
else
    echo -e "${RED}✗${NC} go.mod or go.sum changed, please commit the changes"
    FAILED=1
fi

# Check 3: Run tests
run_check "go test" "go test ./... -v -timeout 60s"

# Check 4: Build check
run_check "go build" "go build -o /dev/null ./..."

# Summary
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}✗ Some pre-commit checks failed. Please fix them before committing.${NC}"
    exit 1
fi
